<!DOCTYPE html>
<html>
  <head>
    <title>BiasHack</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="main-header">
      <div class="header-inner">
        <div class="header-logo">
          <%= link_to "BiasHack", root_path, class: "logo-link" %>
        </div>

        <nav class="header-nav">
          <% if user_signed_in? %>
            <span class="user-greeting">こんにちは、<%= current_user.name %>さん</span>
            <div class="nav-buttons">
              <%= link_to "マイページ", user_path, class: "nav-btn mypage-btn" %>
              <%= link_to edit_user_registration_path, class: "nav-btn settings-btn" do %>
                ⚙️ 設定
              <% end %>
              <%= button_to "ログアウト", destroy_user_session_path, method: :delete, class: "nav-btn logout-btn" %>
            </div>
          <% else %>
            <div class="nav-buttons">
              <%= link_to "新規登録", new_user_registration_path, class: "nav-btn signup-btn" %>
              <%= link_to "ログイン", new_user_session_path, class: "nav-btn login-btn" %>
            </div>
          <% end %>
        </nav>
      </div>
    </header>

    <div class="flash-messages">
      <% if notice %>
        <p class="notice"><%= notice %></p>
      <% end %>
      <% if alert %>
        <p class="alert"><%= alert %></p>
      <% end %>
    </div>

    <main class="main-content">
      <%= yield %>
    </main>
  </body>
</html>
