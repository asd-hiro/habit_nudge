<div class="content-wrapper">
  <div class="status-card">
    <h2 class="page-title">タスクの詳細</h2>

    <div class="info-group">
      <label>内容</label>
      <p class="content-text"><%= @routine.content %></p>
    </div>

    <div class="info-group">
      <label>現在の状態</label>
      <span class="status-badge <%= @routine.status %>">
        <%= @routine.status_i18n %>
      </span>
    </div>

    <hr class="separator">

    <div class="timer-section">
      <% if @routine.doing? %>
        <%# 進行中の場合：計測ログを表示し、達成ボタンを出す %>
        <% current_log = @routine.study_logs.find_by(ended_at: nil) %>
        <div class="active-status">
          <span class="pulse-icon">⚡</span>
          <p>
            現在計測中... 
            <% if current_log %>
              (開始: <%= current_log.started_at.strftime("%H:%M") %>)
            <% end %>
          </p>
        </div>
        <%= button_to "タスクを終了して達成！", update_status_routine_path(@routine), 
              method: :patch, 
              data: { turbo_confirm: "タスクを終了し、経験値を獲得しますか？" },
              class: "btn-action btn-complete" %>

      <% elsif @routine.todo? %>
        <%# 未着手の場合：開始ボタンを出す %>
        <%= button_to "タスクを開始する", start_study_routine_path(@routine), 
              method: :post, 
              class: "btn-action btn-start" %>

      <% else %>
        <%# done (達成済み) の場合：お祝いメッセージのみ %>
        <div class="done-status">
          <p>✅ このタスクは完了しました！</p>
          <p class="exp-get-msg">経験値は獲得済みです。</p>
        </div>
      <% end %>
    </div>

    <div class="sub-actions">
      <%= link_to "編集する", edit_routine_path(@routine), class: "link-edit" %>
      <%= button_to "削除する", routine_path(@routine), 
            method: :delete, 
            form: { data: { turbo_confirm: "本当に削除しますか？" } },
            class: "link-delete" %>
    </div>

    <div class="back-link-container">
      <%= link_to "← 一覧に戻る", user_path, class: "back-link" %>
    </div>
  </div>
</div>