<div class="content-wrapper">
  <div class="form-card">
    <h2 class="page-title">タスクを編集する</h2>
    
    <p class="form-instruction">
      現在の状況に合わせて、活動内容を最適化しましょう。
    </p>

    <%= form_with model: @routine, local: true, class: "routine-form" do |f| %>
      <div class="field">
        <%= f.label :content, "タスク内容" %>
        <%= f.text_area :content, rows: 5, class: "custom-textarea" %>
      </div>

      <div class="actions">
        <%= f.submit "内容を更新する", class: "btn-submit btn-update-theme" %>
      </div>
    <% end %>

    <div class="back-link-container">
      <%= link_to "← マイページに戻る", routine_path(@routine), class: "back-link" %>
    </div>
  </div>
</div>