<div class="content-wrapper">
  <%# 1. キャラクターアラートエリア %>
  <% if @character.present? %>
    <section class="home-character-section">
      <div class="character-alert-card <%= 'is-starving' if @character.starving? %>">
        <% if @character.starving? %>
          <div class="blink-warning">⚠️ 警告：24時間以上学習が空いています！経験値が減少中</div>
        <% end %>

        <div class="char-layout">
          <div class="char-visual">
            <div class="char-img-container">
              <%= @character.image_display %>
            </div>
          </div>

          <div class="char-status-brief">
            <h2 class="char-name-display">
              <%= current_user.character_name %> 
              <span class="level-label">Lv.<%= @character.level %></span>
              <%= link_to edit_user_registration_path, class: "btn-settings-small" do %>
                ⚙️
              <% end %>
            </h2>
            
            <div class="exp-gauge-home">
              <div class="exp-bar-bg">
                <div class="exp-bar-fill" style="width: <%= @character.exp %>%;"></div>
              </div>
              <p class="exp-info-text">
                NEXT: <%= 100 - @character.exp %> EXP (現在: <%= @character.exp %> / 100)
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>
  <% else %>
    <div class="no-character-msg">
      <p>キャラクターを召喚してください。</p>
    </div>
  <% end %>

  <%# 2. 運命のスロット %>
  <section class="slot-section card-box">
    <h3 class="section-title">🎰 運命のスロット</h3>
    <% if @slot_result %>
      <div class="slot-result-display">
        <span class="mission-label">今日の優先ミッション</span>
        <strong class="mission-content"><%= @slot_result %></strong>
      </div>
      <p class="slot-hint">システムが選んだ最善の策です。迷わず開始しましょう！</p>
    <% elsif @character&.slot_available? %>
      <p class="slot-instruction">何から始めるか迷っていませんか？決断をシステムに委ねましょう。</p>
      <%= link_to "スロットを回す", root_path(spin_slot: true), class: "btn-slot-run" %>
    <% else %>
      <p class="slot-instruction-done">本日のミッションは決定済みです。リストを確認してください。</p>
    <% end %>
  </section>

  <%# 3. タスク一覧 %>
  <section class="routine-section">
    <div class="section-header">
      <h2 class="section-title">タスク一覧</h2>
      <%= link_to "すべて見る", user_path, class: "btn-sub-action" %>
    </div>

    <%# --- 修正ポイント：判定を1つにまとめ、コントローラーの変数 @active_routines を使用 --- %>
    <% if @active_routines.present? %>
      <div class="routine-list-grid">
        <% @active_routines.each do |routine| %>
          <div class="routine-item-card">
            <div class="routine-item-main">
              <div class="routine-item-info">
                <%= link_to routine_path(routine), class: "status-link" do %>
                  <span class="status-tag <%= routine.status %>">
                    <%= routine.status_i18n %>
                  </span>
                <% end %>
                <%= link_to routine.content, routine_path(routine), class: "routine-item-link" %>
              </div>
            
              <div class="routine-item-actions">
                <% if routine.todo? %>
                  <%= button_to '開始', start_study_routine_path(routine), method: :post, class: "btn-start-action" %>
                <% elsif routine.doing? %>
                  <%= button_to "達成！", update_status_routine_path(routine), 
                        method: :patch, 
                        data: { turbo_confirm: "タスクを終了し、経験値を獲得しますか？" },
                        class: "btn-start-action", style: "background-color: #2ecc71;" %>
                <% elsif routine.done? %>
                  <span class="done-label">達成済み！</span>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="empty-routine-box">
        <p>現在、未完了のタスクはありません。素晴らしい！</p>
      </div>
    <% end %>
    
    <div style="margin-top: 15px;">
      <%= link_to "＋ タスクを追加", new_routine_path, class: "btn-add-action" %>
    </div>
  </section>
</div>