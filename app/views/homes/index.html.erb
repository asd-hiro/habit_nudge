  <%# 1. キャラクターカードエリア %>
  <% if @character.present? %>
    <div class="character-card <%= 'is-starving' if @character.starving? %>">
      
      <% if @character.starving? %>
        <div class="blink-text">⚠️ 最終学習から24時間経過：経験値が減少中！</div>
      <% end %>

      <div class="rank-label">━━ <%= @character.rank_name %> ━━</div>

      <div class="character-image">
        <%= @character.image_display %>
      </div>

      <h2 style="margin: 0;"><%= @character.name %> <span>(Lv.<%= @character.level %>)</span></h2>
      
      <div class="exp-gauge-container">
        <div class="exp-bar-bg">
          <div class="exp-bar-fill" style="width: <%= @character.exp %>%;"></div>
        </div>
        <p style="font-size: 12px; font-weight: bold; margin-top: 8px; color: <%= @character.starving? ? '#ff4d4f' : '#777' %>;">
          <% if @character.starving? %>
            警告：衰退モード (現在: <%= @character.exp %> / 100)
          <% else %>
            NEXTまで: <%= 100 - @character.exp %> EXP (現在: <%= @character.exp %> / 100)
          <% end %>
        </p>
      </div>
    </div>
  <% else %>
    <p>キャラクターを準備中です...</p>
  <% end %>

  <%# 運命のスロット %>
  <div class="slot-section">
  <h3>🎰 運命のスロット</h3>

  <% if @slot_result %>
    <%# スロットを回した直後、または既に今日回している場合 %>
    <div class="slot-result">
      今日のミッション：<strong><%= @slot_result %></strong>
    </div>
    <p>迷いは禁物です。まずはこのアクションから一日を始めましょう！</p>
  <% elsif @character.slot_available? %>
    <%# まだ今日回していない場合 %>
    <p>二度寝を阻止！今朝の行動をシステムに委ねよう</p>
    <%= link_to "スロットを回す", root_path(spin_slot: true), class: "btn-slot" %>
  <% else %>
    <%# 万が一セッションが切れたがDB上は回し済みの場合の保険 %>
    <p>本日の決断はすでに下されました。学習画面へ進みましょう。</p>
  <% end %>
</div>

  <%# 2. 今日の頑張りエリア %>
  <div class="today-stats">
    <h3 style="margin: 0; color: #856404;">🔥 本日の総学習時間</h3>
    <p class="stats-value">
      <%= @total_duration %> <span style="font-size: 1rem;">分</span>
    </p>
    <div style="color: #8c8c8c; font-size: 0.9rem;">
      完了数: <%= @today_logs.count %> 件
    </div>
  </div>

  <h2>今日のルーティン一覧</h2>
  <%= link_to "＋ 新しいルーティンを登録", new_routine_path, class: "add-link" %>

  <% if @routines.present? %>
    <div class="routine-list">
      <% @routines.each do |routine| %>
        <div class="routine-item">
          <div>
            <strong><%= link_to routine.content, routine_path(routine) %></strong>
            <span style="margin-left: 10px; color: <%= routine.done? ? '#2ecc71' : '#f39c12' %>;">
              [<%= routine.status_i18n %>]
            </span>
            <% current_log = routine.study_logs.find_by(ended_at: nil) %>
            <% if current_log %>
              <br><small style="color: #e67e22;">🕒 計測開始: <%= current_log.started_at.strftime("%H:%M") %></small>
            <% end %>
          </div>

          <div class="actions">
            <% if current_log %>
              <%= button_to '終了して達成！', update_status_routine_path(routine), method: :patch, class: "btn-end", data: { turbo_confirm: '学習を終了しますか？' } %>
            <% elsif routine.todo? %>
              <%= button_to '学習開始', start_study_routine_path(routine), method: :post, class: "btn-start" %>
            <% else %>
              <span style="color: gray;">完了済み</span>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>