<h1>背徳の育成ゲーム</h1>

<%# キャラクター情報エリア %>
<% if current_user.character.present? %>
  <div class="character-info" style="background: #f0f8ff; padding: 15px; border-radius: 8px;">
    <h2><%= current_user.character.name %> (Lv.<%= current_user.character.level %>)</h2>
    <p>現在の経験値: <%= current_user.character.exp %> / 100</p>
  </div>
<% else %>
  <p>キャラクターを準備中です...</p>
<% end %>

<h2>今日のルーティン一覧</h2>

<%= link_to "新しいルーティンを登録する", new_routine_path %>

<% if @routines.present? %>
  <div class="routine-list" style="margin-top: 20px;">
    <% @routines.each do |routine| %>
      <div class="routine-item" style="border: 1px solid #ddd; padding: 10px; margin-bottom: 10px; display: flex; justify-content: space-between; align-items: center;">
    
        <div>
          <strong><%= link_to routine.content, routine_path(routine) %></strong>
          <span class="status-badge" style="margin-left: 10px; color: <%= routine.done? ? 'green' : 'orange' %>;">
            [<%= routine.status_i18n %>]
          </span>
      
          <%# 計測中なら「計測中」と表示する小さなテキストを追加 %>
          <% current_log = routine.study_logs.find_by(ended_at: nil) %>
          <% if current_log %>
            <br><small style="color: #e67e22;">🕒 計測開始: <%= current_log.started_at.strftime("%H:%M") %></small>
          <% end %>
        </div>

        <div class="actions">
          <% if current_log %>
            <%# 【計測中】終了ボタンを表示 %>
            <%= button_to '終了して達成！', update_status_routine_path(routine), 
                method: :patch, 
                data: { turbo_confirm: '学習を終了して達成にしますか？' },
                style: "background-color: #2ecc71; color: white; border: none; padding: 5px 10px; border-radius: 4px;" %>
          <% elsif routine.todo? %>
            <%# 【未着手】開始ボタンを表示 %>
            <%= button_to '学習開始', start_study_routine_path(routine), 
                method: :post,
                style: "background-color: #3498db; color: white; border: none; padding: 5px 10px; border-radius: 4px;" %>
          <% else %>
            <%# 【完了済み】 %>
            <span style="color: gray;">完了済み</span>
          <% end %>
        </div>

      </div>
    <% end %>
  </div>
<% else %>
  <p>まだルーティンが登録されていません。まずは登録してみましょう！</p>
<% end %>

<%# 今日の頑張り（総学習時間）を表示するエリア %>
<div class="today-stats" style="margin: 20px 0; padding: 20px; background: #fffbe6; border: 2px solid #ffe58f; border-radius: 12px; text-align: center;">
  <h3 style="margin: 0; color: #856404; font-size: 1.1rem;">🔥 本日の総学習時間</h3>
  <p style="font-size: 2.5rem; font-weight: bold; margin: 10px 0; color: #d48806;">
    <%= @total_duration %> <span style="font-size: 1rem;">分</span>
  </p>
  <div style="display: flex; justify-content: center; gap: 20px; color: #8c8c8c; font-size: 0.9rem;">
    <span>完了数: <%= @today_logs.count %> 件</span>
  </div>
</div>